# ════════════════════════════════════════════════════════════════
#  TRADING BOT — Environment Configuration
# ════════════════════════════════════════════════════════════════
#
#  Quick start:
#    cp .env.example .env
#    nano .env            # fill in your API keys
#    docker compose up -d --build
#
#  Every variable has a safe default. Only BINANCE_API_KEY and
#  BINANCE_API_SECRET are truly required.
# ════════════════════════════════════════════════════════════════


# ┌──────────────────────────────────────────────────────────────┐
# │  BINANCE EXCHANGE                                            │
# └──────────────────────────────────────────────────────────────┘
# Testnet keys: https://testnet.binancefuture.com
# Live keys:    https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# TRADING_ENV: TESTNET (demo) | LIVE (real money) | SIM (local simulation)
TRADING_ENV=TESTNET

# Legacy alias — kept for backward compatibility
# (ignored if TRADING_ENV is set)
USE_TESTNET=True

# EXECUTION_MODE: LIVE (real orders) | PAPER (simulated limit orders & stops) | SHADOW (simulated immediate market fills)
EXECUTION_MODE=PAPER

# ANALYSIS_ONLY and DRY_RUN are legacy flags. Use EXECUTION_MODE instead.
ANALYSIS_ONLY=True
DRY_RUN=False


# ┌──────────────────────────────────────────────────────────────┐
# │  SYMBOLS & TIMING                                            │
# └──────────────────────────────────────────────────────────────┘
SYMBOLS=BTC/USDT,ETH/USDT

# Seconds between trading cycles
POLLING_INTERVAL=60

# Timeframes for candle analysis
TF_GRID=4h
TF_TREND=1h

# Number of candles to fetch per analysis cycle
CANDLES_ANALYSIS_LIMIT=200


# ┌──────────────────────────────────────────────────────────────┐
# │  RISK MANAGEMENT                                             │
# └──────────────────────────────────────────────────────────────┘
# Maximum leverage allowed per position
MAX_LEVERAGE=20

# Fraction of equity risked per trade (0.01 = 1%)
RISK_PER_TRADE=0.01

# Maximum daily loss before kill switch triggers (0.05 = 5%)
MAX_DAILY_LOSS=0.05

# Automatic kill switch: stops trading if daily loss exceeds limit
KILL_SWITCH_ENABLED=True

# Cooldown between trade attempts (minutes)
COOLDOWN_MINUTES=5.0

# Minimum order size in USDT (Binance requirement)
MIN_NOTIONAL_USD=5.1

# Paper trading mode (virtual balances, no real orders)
PAPER_TRADING_ENABLED=True


# ┌──────────────────────────────────────────────────────────────┐
# │  TELEGRAM NOTIFICATIONS (optional)                           │
# └──────────────────────────────────────────────────────────────┘
# Set TELEGRAM_ENABLED=false to disable completely.
# Even with valid tokens, no messages are sent unless enabled.
TELEGRAM_ENABLED=false
TELEGRAM_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_chat_id

# Granular control (only effective when TELEGRAM_ENABLED=true):
#   ENABLE_TELEGRAM_ALERTS — trade alerts, errors, warnings
#   ENABLE_TELEGRAM_STATUS — periodic status updates (equity, PnL)
ENABLE_TELEGRAM_ALERTS=true
ENABLE_TELEGRAM_STATUS=true


# ┌──────────────────────────────────────────────────────────────┐
# │  DASHBOARD                                                   │
# └──────────────────────────────────────────────────────────────┘
DASHBOARD_ENABLED=true
# Host: 0.0.0.0 (Docker/server) or 127.0.0.1 (local dev)
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000


# ┌──────────────────────────────────────────────────────────────┐
# │  LOGGING & DATA PATHS                                        │
# └──────────────────────────────────────────────────────────────┘
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log

# SQLite database path
DB_PATH=data/trading_v3.db

# Bot state file (read by dashboard)
STATE_FILE=data/dashboard_state.json


# ┌──────────────────────────────────────────────────────────────┐
# │  PRODUCTION OVERRIDES                                        │
# │  Uncomment these when going live with real money:            │
# └──────────────────────────────────────────────────────────────┘
# TRADING_ENV=LIVE
# USE_TESTNET=False
# ANALYSIS_ONLY=False
# PAPER_TRADING_ENABLED=False
# POLLING_INTERVAL=30
# TELEGRAM_ENABLED=true
# MAX_LEVERAGE=10
# RISK_PER_TRADE=0.005
